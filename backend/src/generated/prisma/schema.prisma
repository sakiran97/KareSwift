// Prisma schema for Doorstep Device Service app
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String?        @unique
  passwordHash  String?
  name          String?
  phone         String?        @unique
  role          String         @default("customer") // "customer", "admin"
  otpCode       String?
  otpExpiresAt  DateTime?
  averageRating Float?
  totalReviews  Int?           @default(0)
  createdAt     DateTime       @default(now())
  orders        Order[]        @relation("CustomerOrders")
  notifications Notification[]
  addresses     Address[]
}

model Device {
  id     Int     @id @default(autoincrement())
  brand  String
  model  String
  orders Order[]
}

model ServiceCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)
  orders      Order[]
}

model Order {
  id                Int         @id @default(autoincrement())
  userId            Int
  deviceId          Int
  serviceCategoryId Int
  status            OrderStatus @default(BOOKED)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  completedAt       DateTime?
  estimatedTime     Int? // minutes
  address           String?
  scheduledDate     String?
  scheduledSlot     String?
  diagnosticNotes   String?
  diagnosticPhotos  String[]
  partsUsed         String?
  laborNotes        String?
  finalAmount       Decimal?    @db.Decimal(10, 2)
  paymentMethod     String? // "cash", "upi", "qr"
  completionOtp     String?

  // New Fields for Operator Business Model
  amountConfirmedAt    DateTime?
  completionVerifiedAt DateTime?
  repairNotes          String?
  travelCharge         Decimal?     @db.Decimal(10, 2)
  serviceAreaId        Int?
  serviceArea          ServiceArea? @relation(fields: [serviceAreaId], references: [id])

  user            User            @relation("CustomerOrders", fields: [userId], references: [id])
  device          Device          @relation(fields: [deviceId], references: [id])
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  review          Review?         @relation(name: "ReviewOrder")
  notifications   Notification[]
  warranty        Warranty?       @relation(name: "WarrantyOrder")
}

enum OrderStatus {
  BOOKED
  CONFIRMED
  CUSTOMER_CONTACTED
  DIAGNOSIS_COMPLETED
  VISIT_SCHEDULED
  IN_PROGRESS
  PRICE_FINALIZED
  COMPLETED
  CANCELLED
}

model Review {
  id              Int      @id @default(autoincrement())
  orderId         Int      @unique
  overallRating   Int      @default(5) // 1-5 stars
  serviceQuality  Int      @default(5)
  timeliness      Int      @default(5)
  professionalism Int      @default(5)
  comments        String?
  photos          String[]
  isVerified      Boolean  @default(true)
  createdAt       DateTime @default(now())
  order           Order    @relation(name: "ReviewOrder", fields: [orderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  type      String // "order-update", "chat", "promo"
  isRead    Boolean  @default(false)
  orderId   Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Warranty {
  id           Int      @id @default(autoincrement())
  orderId      Int      @unique
  warrantyDays Int      @default(90)
  expiresAt    DateTime
  claimCount   Int      @default(0)
  createdAt    DateTime @default(now())
  order        Order    @relation(name: "WarrantyOrder", fields: [orderId], references: [id], onDelete: Cascade)
}

model Address {
  id           Int      @id @default(autoincrement())
  userId       Int
  fullName     String
  mobileNumber String
  houseNumber  String
  street       String
  area         String
  landmark     String?
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceArea {
  id           Int      @id @default(autoincrement())
  name         String
  city         String
  travelCharge Decimal  @default(0.00) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Slot {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  startTime   String
  endTime     String
  maxBookings Int      @default(5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
